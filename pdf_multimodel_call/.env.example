# ─────────────────────────────────────────────
# LLM PROVIDER  →  gemini | claude | azure_openai
# ─────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-lite          # override per provider

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-3-5-haiku-20241022   # optional override

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-02-01

# ─────────────────────────────────────────────
# FOLDERS
# ─────────────────────────────────────────────
INPUT_FOLDER=input
OUTPUT_FOLDER=output
LOG_FOLDER=logs
COST_REPORT_FOLDER=cost_reports

# ─────────────────────────────────────────────
# BEHAVIOUR
# ─────────────────────────────────────────────
MAX_RETRIES=3
REQUEST_TIMEOUT=180
THINKING_LEVEL=MINIMAL       # MINIMAL | LOW | HIGH (Gemini only)
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
