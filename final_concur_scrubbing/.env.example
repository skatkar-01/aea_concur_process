# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_MODEL=gpt-4o

# ── Box API (JWT server-side auth) ────────────────────────────────────────────
# Create a Box App at https://developer.box.com → Server Authentication (JWT)
BOX_CLIENT_ID=your_box_client_id
BOX_CLIENT_SECRET=your_box_client_secret
BOX_ENTERPRISE_ID=your_enterprise_id
BOX_JWT_KEY_ID=your_jwt_key_id
BOX_JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ── Box resource IDs ──────────────────────────────────────────────────────────
# Right-click any file/folder in Box web → Copy link → the number at the end is the ID
BOX_TRACKER_FILE_ID=123456789           # 2025 New AmEx Checklist.xlsx
BOX_AMEX_FOLDER_ID=111222333           # AmEx Statements/Individual Statements
BOX_CONCUR_FOLDER_ID=444555666         # Final Concur Reports with Receipts and Approvals

# ── Box webhook signing keys ──────────────────────────────────────────────────
# From: Box Developer Console → Your App → Webhooks → Manage Signatures
BOX_WEBHOOK_PRIMARY_KEY=your_primary_key
BOX_WEBHOOK_SECONDARY_KEY=your_secondary_key

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Azure Portal → Storage Account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_STATE_CONTAINER=amex-state
AZURE_STORAGE_CACHE_CONTAINER=amex-cache

# ── Processing ────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
MAX_RETRIES=3
RETRY_WAIT_SECONDS=2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── LLM cost tracking ─────────────────────────────────────────────────────────
COST_PER_1K_INPUT_TOKENS=0.005
COST_PER_1K_OUTPUT_TOKENS=0.015
