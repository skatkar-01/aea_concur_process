# ══════════════════════════════════════════════════════════════════
# AEA Concur Process — Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────
APP_ENV=development          # development | test | production

# ── Azure OpenAI ──────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure backend: "azure_openai" | "azure_ai_inference"
AZURE_BACKEND=azure_openai

# ── Azure AI Foundry (optional — only if AZURE_BACKEND=azure_ai_inference) ────
# AZURE_AI_ENDPOINT=https://your-model.services.ai.azure.com/models
# AZURE_AI_KEY=your_key_here
# AZURE_AI_MODEL=gpt-4o

# ── Input Folders ─────────────────────────────────────────────────
AMEX_INPUT_FOLDER=inputs/amex       # Drop AMEX PDFs here
CONCUR_INPUT_FOLDER=inputs/concur   # Drop Concur PDFs here

# ── Output ────────────────────────────────────────────────────────
OUTPUT_FOLDER=outputs

# ── Processing ────────────────────────────────────────────────────
MAX_RETRIES=4
CONFIDENCE_THRESHOLD=0.60

# ── Output Formats ────────────────────────────────────────────────
OUTPUT_JSON=true
OUTPUT_CSV=true
OUTPUT_EXCEL=true           # Requires openpyxl

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
